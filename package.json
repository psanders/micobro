{
  "name": "micobro",
  "description": "Offline-first loan tracking for independent lenders in the Dominican Republic, syncing local SQLite with Google Sheets.",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "expo start --clear",
    "android": "expo run:android",
    "build:android": "eas build --platform android --profile preview",
    "build:android:dev": "eas build --platform android --profile development",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:e2e": "maestro test .maestro",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky || true",
    "db:generate": "drizzle-kit generate",
    "start:storybook:native": "STORYBOOK_ENABLED=true expo start",
    "start:demo": "EXPO_PUBLIC_USE_MOCK_REPOS=true expo start"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.2",
    "@expo-google-fonts/sora": "^0.4.2",
    "@expo/metro-runtime": "~56.0.17",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "12.0.1",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "drizzle-orm": "^0.44.0",
    "expo": "~56.0.13",
    "expo-auth-session": "~56.0.4",
    "expo-constants": "~56.0.19",
    "expo-crypto": "~56.0.4",
    "expo-dev-client": "~56.0.21",
    "expo-font": "~56.0.7",
    "expo-linking": "~56.0.14",
    "expo-router": "~56.2.12",
    "expo-secure-store": "~56.0.4",
    "expo-sharing": "~56.0.19",
    "expo-sqlite": "~56.0.5",
    "expo-status-bar": "~56.0.4",
    "expo-web-browser": "~56.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-ble-plx": "^3.5.1",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-nitro-modules": "^0.36.1",
    "react-native-nitro-screen-recorder": "^0.7.0",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-view-shot": "^5.1.0",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.8.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@fission-ai/openspec": "^1.6.0",
    "@storybook/react-native": "^10.4.4",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.2",
    "babel-plugin-inline-import": "^3.0.0",
    "drizzle-kit": "^0.31.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-headers": "^1.3.3",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jest": "~29.7.0",
    "jest-expo": "~56.0.5",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "storybook": "^10.4.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.53.1"
  }
}
